                  "",
                  "pm.test('Auth error message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/tasks",
              "host": ["{{api_url}}"],
              "path": ["tasks"]
            }
          }
        }
