    {
      "name": "RBAC — Role-Based Access Control",
      "description": "Test authorization and access control",
      "item": [
        {
          "name": "Manager Can Create Asset (M1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// M1: Manager should be able to create assets",
                  "pm.test('Status is 201 (Created) or 200', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    pm.test('Created asset has ID', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('id');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{manager_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"assetCode\": \"TEST-{{$timestamp}}\", \"name\": \"Test Asset\", \"location\": \"Building A\", \"status\": \"OPERATIONAL\"}"
            },
            "url": {
              "raw": "{{api_url}}/assets",
              "host": ["{{api_url}}"],
              "path": ["assets"]
            }
          }
        },
        {
          "name": "Technician Cannot Create Asset (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Technician should NOT be able to create assets",
                  "pm.test('Status is 403 (Forbidden)', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Error message returned', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{technician_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"assetCode\": \"DENY-TEST\", \"name\": \"Should Fail\", \"location\": \"Building A\", \"status\": \"OPERATIONAL\"}"
            },
            "url": {
              "raw": "{{api_url}}/assets",
              "host": ["{{api_url}}"],
              "path": ["assets"]
            }
          }
        },
        {
          "name": "Missing Token Returns 401",
          "event": [
            {
              "listen": "test",
              "script": {
