                  "pm.test('Response is array of assets', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Asset objects have required fields', function () {",
                  "    var jsonData = pm.response.json();",
