{
  "info": {
    "_postman_id": "asset-maintenance-api-collection",
    "name": "Asset Maintenance API",
    "description": "API testing collection for Asset Maintenance System\n\nCovers:\n- Authentication workflows (R1/R2/R3)\n- Asset management (R4/R5/R6/R7/R13)\n- Task management (R8/R9/R10/R11)\n- Role-based access control (RBAC)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth — Login",
      "description": "Authentication workflows (R1/R2/R3)",
      "item": [
        {
          "name": "R1 — Manager Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// R1: Manager should get JWT token and redirect to /manager",
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has JWT token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData.token).to.be.a('string');",
                  "    pm.expect(jsonData.token.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Response has user role', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('role');",
                  "    pm.expect(jsonData.role).to.equal('MANAGER');",
                  "});",
                  "",
                  "// Store token for subsequent requests",
                  "pm.environment.set('manager_token', pm.response.json().token);",
                  "pm.environment.set('manager_email', pm.response.json().email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"manager@siemens.com\", \"password\": \"password123\"}"
            },
            "url": {
              "raw": "{{api_url}}/auth/login",
              "host": ["{{api_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "R2 — Technician Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
