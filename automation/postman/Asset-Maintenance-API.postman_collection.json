                  "});",
                  "",
                  "pm.test('Technician role is returned', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.equal('TECHNICIAN');",
                  "});",
                  "",
                  "pm.environment.set('technician_token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
