            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"technician@siemens.com\", \"password\": \"password123\"}"
            },
            "url": {
              "raw": "{{api_url}}/auth/login",
              "host": ["{{api_url}}"],
              "path": ["auth", "login"]
